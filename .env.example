# Supabase browser-safe config for the main app.
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=your_posthog_project_token
VITE_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
VITE_POSTHOG_DEBUG=false

# Supabase local migration/admin scripts only.
# Never prefix service-role credentials with VITE_.
SUPABASE_DB_URL=your_supabase_database_connection_string
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Legacy Firebase export scripts only. Never prefix these with VITE_.
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_SERVICE_ACCOUNT_PATH=path/to/service-account.json

# Server-only AI features. Never prefix this with VITE_.
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.4-mini