    "export:firebase": "node scripts/export-firebase-data.mjs",
    "migrate:firebase-export": "node scripts/migrate-firebase-export.mjs",
    "prebuild": "npm run type-check"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.17",
    "@heroicons/react": "^2.0.18",
    "@supabase/supabase-js": "^2.107.0",
    "chart.js": "^4.4.1",
    "date-fns": "^2.30.0",
    "firebase-admin": "^13.10.0",
    "posthog-js": "^1.235.6",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.4"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
